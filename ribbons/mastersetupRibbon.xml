<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad = "ribbonLoaded">
    <ribbon startFromScratch="false">
        <tabs>
            <tab id="customTab" label="OutbreakTools">
                <group id="customGroupManage" getLabel="LangLabel">
                    <button id="btnAdd" getLabel="LangLabel" imageMso="QueryShowTable" size="large" onAction="clickAddRows"/>
                    <button id="btnRes" getLabel="LangLabel" imageMso="SheetRowsDelete" size="large" onAction="clickResize"/>
                    <button id="btnFilt" getLabel="LangLabel" imageMso="FilterClearAllFilters" size="large" onAction="clickFilters"/>
                    <button id="btnSortTab" getLabel="LangLabel" image="sort" size="large" onAction="clickRibbonSortTable"/>
                </group>
                <group id="customGroupDisease" getLabel="LangLabel">
                    <button id="btnAddSheet" getLabel="LangLabel" image="addsheet" size="large" onAction="clickAddSheet"/>
                    <button id="btnRemSheet" getLabel="LangLabel" imageMso="ClearGrid" size="large" onAction="clickRemSheet"/>
                    <button id="btnClear" getLabel="LangLabel" imageMso="ClearAll" size="large" onAction="clickClearSheet"/>
                </group>
                <group id="customGroupTrans" getLabel="LangLabel">
                    <button id="btnTransAdd" image="translation" getLabel="LangLabel" size="large" onAction="clickAddTrans"/>
                    <editBox id="editLang" getLabel="LangLabel" imageMso="translationPane" onChange="clickAddLang"/>
                    <dropDown id = "langDrop" onAction="clickLangChange" getLabel = "LangLabel">
                        <item id = "FRA" label = "Français" />
                        <item id = "ENG" label = "English" />
                        <item id = "ARA" label = "عربى"/>
                        <item id = "SPA" label = "Español"/>
                        <item id = "POR" label = "Portugués"/>
                    </dropDown>
                </group>
                <group id="customGroupAdv" getLabel="LangLabel">
                    <button id="btnExp" getLabel="LangLabel" image="anaexport" size="large" onAction="clickExpSheet"/>
                    <button id="btnExpMig" getLabel="LangLabel" imageMso="GridSettings" size="normal" onAction="clickExp"/>
                    <button id="btnImpMig" getLabel="LangLabel" imageMso="GridSettings" size="normal" onAction="clickImp"/>
                </group>
                <group id="customGroupDev" getLabel="LangLabel">
                    <button id="btnTransUp" label="Update columns tags" image="sell" size="large" onAction="clickDevUpdateTranslate"/>
                    <button id="btnInit" label="Initialize" image="initialise" size="large" onAction="clickDevInitialize"/>
                    <button id="btnFolder" label="Codes Folder" image="folder" size="large" onAction="clickDevFolder"/>
                    <button id="btnImpCodes" label="Import Codes" image="upload2" size="large" onAction="clickDevImport"/>
                    <button id="btnExpCodes" label="Export Codes" image="download2" size="large" onAction="clickDevExport"/>
                    <button id="btnVBEE" label="Open Editor" image="settings2" size="large" onAction="clickDevVBE"/>
                    <button id="btnDeploy" label="Deploy" image="rocketlaunch" size="large" onAction="clickDevDeploy"/>
                </group>
            </tab>
        </tabs>
    </ribbon>
</customUI>