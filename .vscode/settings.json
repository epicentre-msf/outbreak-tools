{
    "workbench.colorCustomizations": {
        "activityBar.activeBorder": "#606020"
    },
    "files.exclude": {
        "**/.mock": false,
        "Rscripts/designer_aky.xlsb": true,
        "Rscripts/designer_prev.xlsb": true
    },
    "editor.lineNumbers": "on",
    "editor.fontSize": 14,
    "editor.fontFamily": "'Fira Code', Menlo, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "zenMode.hideStatusBar": false,
    "editor.minimap.scale": 1,
    "editor.minimap.renderCharacters": true,
    "githubPullRequests.ignoredPullRequestBranches": [
        "dev"
    ],
    "editor.rulers": [80, 120, 160],
    "editor.inlineSuggest.enabled": false,
    "terminal.integrated.fontSize": 16,
    "terminal.integrated.fontFamily": "'Office Code Pro',  Menlo, 'Courier New', monospace",
    "inline-bookmarks.default.words.green": "@prop\\-title[\\s]",
    "inline-bookmarks.default.words.red": "@section[\\s]",
    "inline-bookmarks.default.words.purple": "@sub\\-title[\\s]",
    "inline-bookmarks.default.words.blue": "@fun\\-title[\\s]",
    "inline-bookmarks.view.words.hide": false,
    "inline-bookmarks.enable": true,
    "inline-bookmarks.view.showVisibleFilesOnly": false,
      "[r]": {
        "editor.formatOnSave": true
    },
    "internalLinker.sourceFolders": ["src"],
    "files.eol": "\r\n"
}