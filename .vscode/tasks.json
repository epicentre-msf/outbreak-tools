    "version": "2.0.0",
    "tasks": [
        {
            "label": "unix2dos src",
            "type": "process",
            "command": "/bin/bash",
            "args": [
                "-lc",
                "find src -type f \\( -name '*.cls' -o -name '*.bas' \\) -print0 | xargs -0 unix2dos"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-NoProfile",
                    "-ExecutionPolicy",
                    "Bypass",
                    "-Command",
                    "Get-ChildItem -Path src -Recurse -Include *.cls,*.bas -File | ForEach-Object { $content = Get-Content -LiteralPath $_.FullName -Raw; $normalized = $content -replace \"`r?`n\", \"`r`n\"; [System.IO.File]::WriteAllText($_.FullName, $normalized) }"
                ]
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
