# =============================================================================
# OutbreakTools .gitignore
# =============================================================================

# --- OS / editor cruft -------------------------------------------------------
.DS_Store
**/.todo

# --- Binaries: stored in the GitHub Release asset store, NOT in git -----------
#   The working binaries live on the 'working-binaries' GitHub Release.
#   Sync with automate/release/pull-assets.{sh,ps1} / push-assets.{sh,ps1}.
#   Versioned release zips are published by .github/workflows/release.yml.
src/bin/
.mock/
releases/
#   Ribbon templates too (the .xlsb binaries only — ribbon XML + icons stay in git).
#   Still in git HISTORY for now; folded into a later history-rewrite pass.
ribbons/_ribbontemplate_main.xlsb
ribbons/_ribbontemplate_dev.xlsb

# --- VS Code: commit project tasks/snippets, ignore personal settings --------
#   tasks.json + snippets are shared; settings.json is per-developer.
#   (.gitattributes already enforces CRLF for *.cls/*.bas, so settings.json is
#    not needed to keep VBA line endings correct.)
.vscode/*
!.vscode/tasks.json
!.vscode/obt-snippet.code-snippets

# --- Node --------------------------------------------------------------------
/node_modules
logs

# --- R -----------------------------------------------------------------------
*.Rmd
*.Rproj
.Rproj.user
.Rprofile
.Renviron

# --- Quarto / generated docs -------------------------------------------------
.quarto/
/.quarto/
docs/
site/dev
src/.docignore

# --- Temp / scratch / build output -------------------------------------------
temp
*.temp
*.temporary
*.test
output
outputs
output_test
migration
migrations
demo
local
debug
config.json

# --- VBA editor artifacts ----------------------------------------------------
*Sheet1.cls
*Sheet2.cls
*Sheet3.cls
*Sheet4.cls
*Sheet5.cls
**/~$*.xlsb

# --- Assistant workspace + local skill copies --------------------------------
/.obt
obt-skill/
obt-doc-skill/

#------- Rewrite workflow
automate/history-rewrite